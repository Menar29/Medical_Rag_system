# ── Copier ce fichier en .env puis remplacer les valeurs sensibles ────────────
# cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=cerviscan
POSTGRES_USER=cerviscan
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432

# ── Ollama (LLM, GPU) ─────────────────────────────────────────────────────────
# gemma4 = variante par defaut. Sur GPU, possibilite d'epingler une taille :
# gemma4:e4b (leger), gemma4:12b, gemma4:26b, gemma4:31b.
OLLAMA_MODEL=gemma4
OLLAMA_PORT=11434
OLLAMA_KEEP_ALIVE=24h
OLLAMA_NUM_PARALLEL=2

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
# cpu (defaut) ou cuda (necessite un build torch CUDA + gpus:all sur le backend)
EMBEDDING_DEVICE=cpu

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
API_KEY=change_me_api_key
JWT_SECRET=change_me_jwt_secret
REQUIRE_API_KEY=true
CORS_ORIGINS=http://localhost:8080

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=8080
VITE_API_BASE=http://localhost:8000/api/v1
# Le frontend reutilise automatiquement API_KEY (voir docker-compose: VITE_API_KEY=${API_KEY}).
# A noter : une cle exposee dans un bundle frontend est publique par nature.
